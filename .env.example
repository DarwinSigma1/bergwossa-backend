# PostgreSQL Database
# On Railway: set DATABASE_URL (provided automatically by the Postgres plugin)
# Locally: use the individual vars below
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bergwossa
DB_USER=postgres
DB_PASSWORD=your-db-password

# HiveMQ Cloud MQTT Broker
MQTT_BROKER_URL=your-broker.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (für CORS)
FRONTEND_URL=http://localhost:4200

# Keycloak (optional, später)
# KEYCLOAK_PUBLIC_KEY=...
